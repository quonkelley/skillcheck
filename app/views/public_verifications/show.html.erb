<div class="max-w-xl w-full bg-white shadow-lg rounded-xl p-8 border border-emerald-200">
  <div class="flex items-center mb-6">
    <div class="flex items-center justify-center w-12 h-12 rounded-full bg-emerald-100 text-emerald-600 mr-4">
      <!-- Simple "verified" check icon -->
      <span class="text-2xl">✓</span>
    </div>
    <div>
      <p class="text-sm font-semibold tracking-wide text-emerald-600 uppercase">
        Verified Credential
      </p>
      <h1 class="text-2xl font-bold text-slate-900">
        <%= @verification.skill_name %>
      </h1>
    </div>
  </div>

  <div class="space-y-2 mb-6">
    <p class="text-sm text-slate-600">
      Issued by:
      <span class="font-medium text-slate-900"><%= @verification.mentor.name %></span>
    </p>
    <p class="text-sm text-slate-600">
      To:
      <span class="font-medium text-slate-900"><%= @verification.learner.name %></span>
    </p>
    <p class="text-sm text-slate-600">
      Date of issuance:
      <span class="font-medium text-slate-900">
        <%= @verification.created_at.strftime("%B %d, %Y") %>
      </span>
    </p>
  </div>

  <% if @verification.metadata.present? && @verification.metadata["evidence_url"].present? %>
    <div class="mt-4">
      <p class="text-sm font-semibold text-slate-700 mb-1">
        Evidence
      </p>
      <a
        href="<%= @verification.metadata["evidence_url"] %>"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center text-sm font-medium text-emerald-700 hover:text-emerald-900 underline"
      >
        View supporting evidence
      </a>
    </div>
  <% end %>
</div>

